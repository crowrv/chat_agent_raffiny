# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Your own Telegram user ID (message @userinfobot to find it)
BAKER_CHAT_ID=your-telegram-user-id

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Google OAuth2 ────────────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CREDENTIALS_FILE=credentials.json
# Generated by running: python auth_google.py
GOOGLE_TOKEN_FILE=token.json

# ── Raffin Data ──────────────────────────────────────────────────────────────
SHEET_ID=1TLz40s9KAW6STWIERg4sqsFbIFQh5iOWAx27LxhF8qE
BUSINESS_EMAIL=business@raffin.studio

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
# Public HTTPS URL for Telegram to deliver webhooks to
WEBHOOK_URL=https://your-server.example.com

# ── Agent config (populated automatically by setup_agent.py) ─────────────────
AGENT_ID=
AGENT_VERSION=
ENVIRONMENT_ID=
