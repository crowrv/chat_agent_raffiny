# Telegram bot token from @BotFather (https://t.me/BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Shared instance id: hub rejects session binds whose id does not match.
TELEGRAM_HUB_ID=local-dev

# Hub WebSocket server (sessions connect here)
TELEGRAM_HUB_PORT=4713
TELEGRAM_HUB_BIND_ADDR=127.0.0.1
TELEGRAM_HUB_HOST=127.0.0.1
TELEGRAM_HUB_LOG_FILE=/tmp/telegram-claude-hub.log

# Telegram Bot API base. Only override for a self-hosted Bot API server
# (https://core.telegram.org/bots/api#using-a-local-bot-api-server) or tests.
# TELEGRAM_API_BASE=https://api.telegram.org

# Session binding, read by src/channel.ts when Claude Code starts:
#   TELEGRAM_CHAT=<chat_id>  -> dedicated session for one chat
#   TELEGRAM_CHAT=* (or unset) -> fallback session for all unrouted chats
TELEGRAM_CHAT=*
