# Telegram bot token from @BotFather (https://t.me/BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Shared instance id: hub rejects session binds whose id does not match.
TELEGRAM_HUB_ID=local-dev

# Hub WebSocket server (sessions connect here)
TELEGRAM_HUB_PORT=4713
TELEGRAM_HUB_BIND_ADDR=127.0.0.1
TELEGRAM_HUB_HOST=127.0.0.1
TELEGRAM_HUB_LOG_FILE=/tmp/telegram-claude-hub.log

# Telegram Bot API base. Only override for a self-hosted Bot API server
# (https://core.telegram.org/bots/api#using-a-local-bot-api-server) or tests.
# TELEGRAM_API_BASE=https://api.telegram.org

# Session binding, read by src/channel.ts when Claude Code starts:
#   TELEGRAM_CHAT=<chat_id>  -> dedicated session for one chat
#   TELEGRAM_CHAT=* (or unset) -> fallback session for all unrouted chats
TELEGRAM_CHAT=*

# Raffin role sessions. Telegram Review is where customer request decisions and
# Instagram draft approvals happen. Telegram Ops is where the operator manages
# the program itself (status/restart/logs/polling).
RAFFIN_REVIEW_TELEGRAM_CHAT_ID=
RAFFIN_OPS_TELEGRAM_CHAT_ID=
# Set per Claude session when launching manually: review | ops
# RAFFIN_SESSION_ROLE=review

# Whether fleet startup should also start Instagram polling. Keep this off by
# default so starting Claude sessions does not silently monitor customer DMs.
RAFFIN_START_IG_SOURCE=0
# Keep IG polling from reading/acknowledging inbox rows until the review Claude
# session is bound on the hub.
IG_REQUIRE_REVIEW_SESSION=1

# Backwards-compatible alias for the review chat. Prefer
# RAFFIN_REVIEW_TELEGRAM_CHAT_ID for new setups.
BAKER_TELEGRAM_CHAT_ID=
